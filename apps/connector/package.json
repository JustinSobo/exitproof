{
  "name": "@exitproof/hybrid-connector",
  "version": "0.1.0",
  "private": true,
  "description": "ExitProof Hybrid AD Connector — outbound HTTPS Windows agent skeleton",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "heartbeat": "tsx src/index.ts --once heartbeat",
    "snapshot": "tsx src/index.ts --once snapshot",
    "test": "tsx --test src/**/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.20.5",
    "typescript": "^5"
  }
}
