# ExitProof environment variables
# Copy to .env.local for local development

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEMO_MODE=true

# Supabase (required when DEMO_MODE=false)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Needed for Stripe/cron/webhooks and for Entra domain JIT org join on /auth/callback
SUPABASE_SERVICE_ROLE_KEY=

# Microsoft Entra ID (Azure AD) SSO via Supabase Auth
# Do NOT put Entra client secrets in this app. Configure them only in:
#   Supabase Dashboard → Authentication → Providers → Azure
# App code uses provider: 'azure' with scopes: email openid profile
# See README → "Microsoft Entra SSO (Azure provider)"

# Stripe Billing (STRIPE_WEBHOOK_SECRET required when Stripe is enabled — fail closed)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_AGENCY=

# Resend (overdue critical-step emails — graceful no-op if unset)
RESEND_API_KEY=
RESEND_FROM_EMAIL=ExitProof <onboarding@resend.dev>

# Cron protection for /api/cron/overdue (required when DEMO_MODE=false — fail closed)
CRON_SECRET=
