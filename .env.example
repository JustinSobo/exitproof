# ExitProof environment variables
# Copy to .env.local for local development

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEMO_MODE=true

# Supabase (required when DEMO_MODE=false)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_AGENCY=

# Resend (overdue critical-step emails — graceful no-op if unset)
RESEND_API_KEY=
RESEND_FROM_EMAIL=ExitProof <onboarding@resend.dev>

# Cron protection for /api/cron/overdue
CRON_SECRET=
